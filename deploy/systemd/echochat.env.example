# Echo-Chat environment (systemd EnvironmentFile)
#
# Copy to: /etc/echochat/echochat.env
# Set permissions: chmod 600 /etc/echochat/echochat.env

# Prevent secrets from being written to server_config.json
ECHOCHAT_PERSIST_SECRETS=0

# Path to the Echo-Chat JSON config file (used by wsgi.py / janitor_runner.py)
ECHOCHAT_CONFIG=/opt/echochat/Echo-Chat-main/server_config.json

# Core secrets
SECRET_KEY=change_me_to_a_long_random_value
JWT_SECRET_KEY=change_me_to_a_different_long_random_value
DATABASE_URL=postgresql://YOUR_LOCAL_PG_USER@localhost:5432/echochat

# Redis (recommended for public beta and required before scaling)
ECHOCHAT_RATE_LIMIT_STORAGE_URI=redis://127.0.0.1:6379/0
ECHOCHAT_SOCKETIO_MESSAGE_QUEUE=redis://127.0.0.1:6379/1
ECHOCHAT_SHARED_STATE_REDIS_URL=redis://127.0.0.1:6379/2
REDIS_URL=redis://127.0.0.1:6379/1

# Optional overrides
# ECHOCHAT_CORS_ALLOWED_ORIGINS=https://chat.example.com,https://admin.example.com

# External URL and proxy/TLS settings
ECHOCHAT_PUBLIC_BASE_URL=https://chat.example.com
ECHOCHAT_COOKIE_SECURE=1
ECHOCHAT_COOKIE_SAMESITE=Lax
ECHOCHAT_TRUST_PROXY_HEADERS=1
ECHOCHAT_PROXY_FIX_HOPS=1
ECHOCHAT_ENABLE_HEALTH_ENDPOINT=1
ECHOCHAT_HEALTH_ENDPOINT=/health

# Socket.IO / Gunicorn beginner-safe default
ECHOCHAT_SOCKETIO_ASYNC=threading
ECHOCHAT_SOCKETIO_TRANSPORTS=polling
ECHOCHAT_GUNICORN_WORKER_CLASS=gthread
ECHOCHAT_GUNICORN_THREADS=100

# Production runner. The ECHOCHAT_PRODUCTION_* names feed python main.py --production;
# ECHOCHAT_BIND/ECHOCHAT_WORKERS are direct gunicorn_conf.py aliases.
ECHOCHAT_RUN_MODE=production
ECHOCHAT_PRODUCTION_MODE=1
ECHOCHAT_PRODUCTION_BIND=127.0.0.1:5000
ECHOCHAT_PRODUCTION_WORKERS=1
ECHOCHAT_BIND=127.0.0.1:5000
ECHOCHAT_WORKERS=1

# GIFs
GIPHY_API_KEY=

# SMTP (password reset)
ECHOCHAT_SMTP_ENABLED=0
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Echo-Chat <no-reply@localhost>
SMTP_STARTTLS=1
SMTP_SSL=0

# Optional SMS 2FA / Twilio Verify
ECHOCHAT_ENABLE_SMS_TWO_FACTOR=0
ECHOCHAT_ENABLE_TWO_FACTOR_BETA=0
ECHOCHAT_TWILIO_VERIFY_CHANNEL=sms
ECHOCHAT_TWILIO_ACCOUNT_SID=
ECHOCHAT_TWILIO_AUTH_TOKEN=
ECHOCHAT_TWILIO_VERIFY_SERVICE_SID=
ECHOCHAT_TWO_FACTOR_LOGIN_TIMEOUT_SECONDS=600

# Optional Dynamic DNS helper. Use this if your home/public IP changes and your DDNS provider supports an update URL.
ECHOCHAT_DYNAMIC_DNS_ENABLED=0
ECHOCHAT_DYNAMIC_DNS_PROVIDER=No-IP
ECHOCHAT_DYNAMIC_DNS_DOMAIN=
ECHOCHAT_DYNAMIC_DNS_USERNAME=
ECHOCHAT_DYNAMIC_DNS_PASSWORD=
ECHOCHAT_DYNAMIC_DNS_UPDATE_URL=https://dynupdate.no-ip.com/nic/update

# Optional WebRTC TURN relay. STUN-only can be blank; TURN needs URL, username, and credential.
ECHOCHAT_TURN_URLS=
ECHOCHAT_TURN_USERNAME=
ECHOCHAT_TURN_CREDENTIAL=


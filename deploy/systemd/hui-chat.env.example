# Hui Chat environment (systemd EnvironmentFile)
#
# Copy to: /etc/hui/hui-chat.env
# Set permissions: chmod 600 /etc/hui/hui-chat.env

# Prevent secrets from being written to server_config.json
HUI_PERSIST_SECRETS=0

# Path to the Hui Chat JSON config file (used by wsgi.py / janitor_runner.py)
HUI_CONFIG=/opt/hui/hui-chat/server_config.json

# Core secrets
# Generate real secrets with: python main.py --generate-secrets --write-env-secrets
# Or paste output from: python main.py --generate-secrets
SECRET_KEY=GENERATE_WITH_python_main_py_generate_secrets
JWT_SECRET_KEY=GENERATE_WITH_python_main_py_generate_secrets
HUI_PROFILE_FIELD_KEY=GENERATE_WITH_python_main_py_generate_secrets
HUI_EMAIL_FIELD_KEY=GENERATE_WITH_python_main_py_generate_secrets
HUI_EMAIL_HASH_KEY=GENERATE_WITH_python_main_py_generate_secrets
HUI_SECURITY_BACKUP_KEY=GENERATE_WITH_python_main_py_generate_secrets
HUI_PRIVACY_HASH_KEY=GENERATE_WITH_python_main_py_generate_secrets
DATABASE_URL=postgresql://YOUR_LOCAL_PG_USER@localhost:5432/hui_chat

# Redis (recommended for public beta and required before scaling)
HUI_RATE_LIMIT_STORAGE_URI=redis://127.0.0.1:6379/0
HUI_SOCKETIO_MESSAGE_QUEUE=redis://127.0.0.1:6379/1
HUI_SHARED_STATE_REDIS_URL=redis://127.0.0.1:6379/2
# REDIS_URL is intentionally not used for Socket.IO; keep the explicit DB split above.

# Optional overrides
# HUI_CORS_ALLOWED_ORIGINS=https://chat.example.com,https://admin.example.com

# External URL and proxy/TLS settings
HUI_PUBLIC_BASE_URL=https://chat.example.com
HUI_COOKIE_SECURE=1
HUI_COOKIE_SAMESITE=Lax
HUI_TRUST_PROXY_HEADERS=1
HUI_PROXY_FIX_HOPS=1
HUI_FORWARDED_ALLOW_IPS=127.0.0.1
HUI_ENABLE_HEALTH_ENDPOINT=1
HUI_HEALTH_ENDPOINT=/health

# Socket.IO / Gunicorn beginner-safe default
HUI_SOCKETIO_ASYNC=threading
HUI_SOCKETIO_TRANSPORTS=polling
HUI_GUNICORN_WORKER_CLASS=gthread
HUI_GUNICORN_THREADS=100

# Production runner. Bind/port comes from server_config.json for hui-chat.service.
# The hui-chat@PORT template overrides bind per instance inside ExecStart.
HUI_RUN_MODE=production
HUI_PRODUCTION_MODE=1
HUI_PRODUCTION_WORKERS=1
HUI_PRODUCTION_INSTANCES=1
HUI_INSTANCE_BASE_PORT=5000
HUI_WORKERS=1

# GIFs
GIPHY_API_KEY=

# SMTP (password reset)
HUI_SMTP_ENABLED=0
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Hui Chat <no-reply@localhost>
SMTP_STARTTLS=1
SMTP_SSL=0

# Optional SMS 2FA / Twilio Verify
HUI_ENABLE_SMS_TWO_FACTOR=0
HUI_ENABLE_TWO_FACTOR_BETA=0
HUI_TWILIO_VERIFY_CHANNEL=sms
HUI_TWILIO_ACCOUNT_SID=
HUI_TWILIO_AUTH_TOKEN=
HUI_TWILIO_VERIFY_SERVICE_SID=
HUI_TWO_FACTOR_LOGIN_TIMEOUT_SECONDS=600

# Optional Dynamic DNS helper. Use this if your home/public IP changes and your DDNS provider supports an update URL.
HUI_DYNAMIC_DNS_ENABLED=0
HUI_DYNAMIC_DNS_PROVIDER=No-IP
HUI_DYNAMIC_DNS_DOMAIN=
HUI_DYNAMIC_DNS_USERNAME=
HUI_DYNAMIC_DNS_PASSWORD=
HUI_DYNAMIC_DNS_UPDATE_URL=https://dynupdate.no-ip.com/nic/update

# Optional WebRTC TURN relay. STUN-only can be blank; TURN needs URL, username, and credential.
HUI_TURN_URLS=
HUI_TURN_USERNAME=
HUI_TURN_CREDENTIAL=

